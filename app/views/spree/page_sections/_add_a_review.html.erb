<% cache_unless page_builder_enabled?, spree_base_cache_scope.call(section) do %>
  <% if current_user %>
    <% unless !section.preferred_allow_unverified_purchase_reviews && current_user.recent_purchase_date_for(@product) == nil %>
      <% if section.blocks.any? %>
        <div class="page-container" style="<%= section_styles(section) %>">
          <% section.blocks.includes(:rich_text_text).each do |block| %>
            <% case block.type %>
            <% when 'Spree::PageBlocks::Heading' %>
              <h2 class="<%= block.preferred_size == 'small' ? 'text-lg' : (block.preferred_size == 'medium' ? 'text-2xl' : 'text-2xl') %> font-medium" <%= block_attributes(block) %>>
                <%= block.text %>
              </h2>
            <% when 'Spree::PageBlocks::Text' %>
              <div class="max-w-prose text-md leading-relaxed font-normal" <%= block_attributes(block) %>>
                <%= block.text %>
              </div>
            <% when 'Spree::PageBlocks::ProductReviewForm' %>
              <% user_product_review = current_user&.product_review_for(@product) %>
              <% if user_product_review.present? %>
                <%= render "spree/product_reviews/pending", product_review: user_product_review %>
              <% else %>
                <%= render "spree/product_reviews/form", product: @product, product_review: Spree::ProductReview.new(product: @product), block: block %>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% end %>
